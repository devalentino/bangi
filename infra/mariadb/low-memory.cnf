[mysqld]
# Keep global buffers small enough for a 160 MB container.
max_connections = 20
thread_cache_size = 16
table_open_cache = 128

# InnoDB still backs non-tracker tables, so keep it available but small.
innodb_buffer_pool_size = 32M
innodb_buffer_pool_instances = 1
innodb_log_buffer_size = 4M

# Tracker tables use Aria, so reserve some page cache for it as well.
aria_pagecache_buffer_size = 16M
key_buffer_size = 8M

# Keep per-connection transient memory under control.
tmp_table_size = 8M
max_heap_table_size = 8M
sort_buffer_size = 256K
join_buffer_size = 256K
read_buffer_size = 128K
read_rnd_buffer_size = 256K

# Disable optional memory-heavy instrumentation in this small container.
performance_schema = OFF
query_cache_type = OFF
query_cache_size = 0
